{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    
    /* Path Mapping - CRITICAL */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["src/shared/*"],
      "@pages/*": ["src/pages/*"],
      "@components/*": ["src/shared/components/*"],
      
      /* Layout components */
      "@layout/*": ["src/shared/components/layout/*"],
      "@forms/*": ["src/shared/components/forms/*"],
      "@common/*": ["src/shared/components/common/*"],
      "@modals/*": ["src/shared/components/modals/*"],
      "@feedback/*": ["src/shared/components/feedback/*"],
      "@communication/*": ["src/shared/components/communication/*"],
      "@data-display/*": ["src/shared/components/data/display/*"],
      "@buttons/*": ["src/shared/components/buttons/*"],
      "@medical/*": ["src/shared/components/medical/*"],
      "@panels/*": ["src/shared/components/panels/*"],
      "@navigation/*": ["src/shared/components/navigation/*"],
      "@tracking/*": ["src/shared/components/tracking/*"],
      "@cards/*": ["src/shared/components/cards/*"],
      "@dashboard/*": ["src/shared/components/dashboard/*"],
      "@dragdrop/*": ["src/shared/components/drag/drop/*"],
      "@facility/*": ["src/shared/components/facility/*"],
      "@patient/*": ["src/shared/components/patient/*"],
      "@documents/*": ["src/shared/components/documents/*"],
      "@calendar/*": ["src/shared/components/calendar/*"],
      "@scheduling/*": ["src/shared/components/scheduling/*"],
      "@system/*": ["src/shared/components/system/*"],
      "@teleconsult/*": ["src/shared/components/teleconsultation/*"],
  
      /* Shared utilities */
      "@hooks/*": ["src/shared/hooks/*"],
      "@services/*": ["src/shared/services/*"],
      "@constants/*": ["src/shared/constants/*"],
      "@types/*": ["src/shared/types/*"],
      "@utils/*": ["src/shared/utils/*"],
      "@mocks/*": ["src/shared/mocks/*"],
      "@validators/*": ["src/shared/validators/*"],
      "@calculators/*": ["src/shared/calculators/*"],
      "@formatters/*": ["src/shared/formatters/*"],
      "@transformers/*": ["src/shared/transformers/*"],
      "@filters/*": ["src/shared/filters/*"],
      "@sorters/*": ["src/shared/sorters/*"],
      "@config/*": ["src/shared/config/*"],
      "@builders/*": ["src/shared/builders/*"],
      "@contexts/*": ["src/shared/contexts/*"],
      "@enums/*": ["src/shared/enums/*"],
      "@parsers/*": ["src/shared/parsers/*"],
      "@generators/*": ["src/shared/generators/*"],
      "@mappers/*": ["src/shared/mappers/*"],

      /* Pages */
      "@router/*": ["src/router/*"],
      "@admin/*": ["src/pages/admin/*"],
      "@secretary-primary/*": ["src/pages/secretary-primary/*"],
      "@doctor/*": ["src/pages/doctor/*"],
      "@nurse/*": ["src/pages/nurse/*"],
      "@secretary-secondary/*": ["src/pages/secretary-secondary/*"],
      "@shared-admin/*": ["src/pages/shared/administrative/*"],
      "@shared-medical/*": ["src/pages/shared/medical/*"],
      "@shared-technical/*": ["src/pages/shared/technical/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}